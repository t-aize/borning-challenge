# Environment: "development" (seed data) or "production" (MongoDB)
ENV=development

# MongoDB (used only when ENV=production)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=borning_challenge

# CORS origins (comma-separated in env, list in code)
# Development: ["*"]  |  Production: ["https://borning-challenge.alstom.com"]
CORS_ORIGINS=["*"]

